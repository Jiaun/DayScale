generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model SysUser {
  /// Primary key
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  /// Login username
  username          String    @unique(map: "uk_sys_user_username") @db.VarChar(64)
  /// Display nickname
  nickname          String?   @db.VarChar(64)
  /// Real name
  realName          String?   @map("real_name") @db.VarChar(64)
  /// Email address
  email             String?   @unique(map: "uk_sys_user_email") @db.VarChar(128)
  /// Whether the email has been verified by Better Auth
  emailVerified     Boolean   @default(false) @map("email_verified")
  /// Mobile phone number
  phone             String?   @unique(map: "uk_sys_user_phone") @db.VarChar(32)
  /// Legacy password mirror. Better Auth stores credential hashes in `account.password`.
  passwordHash      String    @default("") @map("password_hash") @db.VarChar(255)
  /// User avatar URL
  avatarUrl         String?   @map("avatar_url") @db.VarChar(255)
  /// Gender: 0 unknown, 1 male, 2 female
  gender            Int       @default(0) @db.TinyInt
  /// Status: 1 enabled, 0 disabled
  status            Int       @default(1) @db.TinyInt
  /// User type: 0 normal, 1 admin
  userType          Int       @default(0) @map("user_type") @db.TinyInt
  /// Whether this is a built-in system account
  isSystem          Boolean   @default(false) @map("is_system")
  /// Total login count
  loginCount        Int       @default(0) @map("login_count") @db.UnsignedInt
  /// Last login time
  lastLoginAt       DateTime? @map("last_login_at")
  /// Last login IP
  lastLoginIp       String?   @map("last_login_ip") @db.VarChar(45)
  /// Last password update time
  passwordUpdatedAt DateTime? @map("password_updated_at")
  /// Remark
  remark            String?   @db.VarChar(500)
  /// Record creation time
  createdAt         DateTime  @default(now()) @map("created_at")
  /// Record update time
  updatedAt         DateTime  @updatedAt @map("updated_at")
  /// Soft delete time, null means active
  deletedAt         DateTime? @map("deleted_at")
  accounts          Account[]
  sessions          Session[]

  @@index([status], map: "idx_sys_user_status")
  @@index([deletedAt], map: "idx_sys_user_deleted_at")
  @@index([createdAt], map: "idx_sys_user_created_at")
  @@map("sys_user")
}

model Account {
  id                    BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  accountId             String    @map("account_id") @db.VarChar(255)
  providerId            String    @map("provider_id") @db.VarChar(128)
  userId                BigInt    @map("user_id") @db.UnsignedBigInt
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  idToken               String?   @map("id_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?   @db.VarChar(255)
  password              String?   @db.VarChar(255)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  SysUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId], map: "uk_account_provider_account")
  @@index([userId], map: "idx_account_user_id")
  @@map("account")
}

model Session {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt    @map("user_id") @db.UnsignedBigInt
  expiresAt DateTime  @map("expires_at")
  token     String    @unique(map: "uk_session_token") @db.VarChar(255)
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  userAgent String?   @map("user_agent") @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      SysUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_session_user_id")
  @@map("session")
}

model Verification {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  identifier String   @unique(map: "uk_verification_identifier") @db.VarChar(255)
  value      String   @db.Text
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verification")
}
